<Window x:Class="MessengerClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MessengerClient"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="Логин: "/>
        <TextBox Width="200" x:Name="LoginBox"/>
        <TextBlock Text="Пароль: " Margin="0,10,0,0"/>
        <PasswordBox Width="200" x:Name="PasswordBox"/>
        <Button Content="Войти" Click="LoginButton_Click" Name="LoginButton" Width="100" Margin="0,15,0,0"/>
        <TextBlock x:Name="ErrorText" Foreground="Red" Margin="0,10,0,0" TextAlignment="Center" />
    </StackPanel>
</Window>
